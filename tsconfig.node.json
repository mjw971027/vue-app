/**
 * ============================================================
 * 文件：tsconfig.node.json
 * 作用：Node 环境 TypeScript 配置（仅用于 vite.config.ts）
 * 说明：
 *   - 只编译 vite.config.ts 一个文件
 *   - 使用 ES2023 作为编译目标（Node 20+ 原生支持）
 *   - module: "esnext" + moduleResolution: "bundler"
 *     与 Vite 的 ESM 构建模式保持一致
 * ============================================================
 */

{
  "compilerOptions": {
    /* 增量编译缓存文件路径 */
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",

    /* 编译目标：ES2023（Node.js 20+ 原生支持，无需降级） */
    "target": "ES2023",

    /* lib：编译时使用的类型库
       ES2023 — 提供 ES2023+ 的全局类型（Array.prototype.toSorted 等） */
    "lib": ["ES2023"],

    /* 模块系统：ESNext（保持 ESM 格式，Node 20+ 原生支持） */
    "module": "ESNext",

    /* 类型定义：引入 Node.js 的类型（process、fs、path 等） */
    "types": ["node"],

    /* 跳过第三方库（node_modules）的类型检查，加快编译速度 */
    "skipLibCheck": true,

    /* ========== Bundler 模式（与 Vite 对齐）========== */

    /* 模块解析策略：bundler
       行为类似 Node.js 的 ESM 解析，但更宽松
       支持：省略 .ts 扩展名、package.json 的 exports 字段等
       这是 Vite/Webpack 等打包工具的推荐设置 */
    "moduleResolution": "bundler",

    /* 允许直接 import .ts/.tsx 扩展名（Vite 支持，Node 原生不支持但打包时会处理） */
    "allowImportingTsExtensions": true,

    /* 强制使用 verbatim 模块语法（import type / import 严格区分）
       与 allowImportingTsExtensions 配合使用
       确保类型导入不会影响运行时代码 */
    "verbatimModuleSyntax": true,

    /* 强制模块检测模式为 "force"
       确保所有文件都被视为模块（有 import/export 的文件）
       避免意外把脚本文件当作全局脚本处理 */
    "moduleDetection": "force",

    /* 只做类型检查，不输出 .js 文件
       true：tsc 只检查类型错误，不生成文件
       因为 Vite 自己负责编译 .ts 文件，不需要 tsc 输出 */
    "noEmit": true,

    /* ========== Lint 规则（与应用配置保持一致）========== */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },

  /* include — 只编译 vite.config.ts（配置文件本身） */
  "include": ["vite.config.ts"]
}
